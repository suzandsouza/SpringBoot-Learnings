<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans 
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->

	<bean id="specification1" class="com.autowiring.by.name.Specification">
		<property name="make" value="Toyota"></property>
		<property name="model" value="Corolla"></property>
	</bean>
	
	<bean id="car" autowire="byName" class="com.autowiring.by.name.Car"></bean>
</beans>
