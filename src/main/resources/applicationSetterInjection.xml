<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans 
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
	<bean id="specification" class="com.setter.example.injection.Specification">
	<property name="make" value="Toyota"></property>
	<property name="model" value="Corolla"></property>
	</bean>
	
<!-- Now this bean's creation responsibility is given to the contrcutor  -->	
	<bean id="car" class="com.setter.example.injection.Car">
		<!-- setter injection is applied using property name-->
		<!-- in setter we make use of ref it is the ref of the bean created above-->
		<property name="specification" ref="specification"></property>
	</bean>
</beans>